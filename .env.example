# ─── Brevo ────────────────────────────────────────────
# Obter em: app.brevo.com → SMTP & API → API Keys
BREVO_API_KEY=xkeysib-...

# ID da lista de contatos criada no Brevo para este projeto
# Obter em: Contacts → Lists → ID numérico da lista
BREVO_CONTACT_LIST_ID=1

# ID do template de e-mail transacional do magic link
# Obter em: Email → Templates → ID numérico do template
BREVO_MAGIC_LINK_TEMPLATE_ID=1

# ─── Redis ────────────────────────────────────────────
# URL de conexão Redis (Redis Cloud, Upstash, etc.)
# Formato: redis://default:SENHA@host:porta
REDIS_URL=redis://default:...@host:porta

# ─── App ──────────────────────────────────────────────
# URL pública do site (sem barra no final)
# Em desenvolvimento: http://localhost:3000
# Em produção: https://cidadaniaesustentabilidade.com.br
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Segredo para HMAC dos tokens de magic link
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MAGIC_LINK_SECRET=
